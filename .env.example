# Keycloak-only stack environment template
# Copy this file to .env in keycloak-stack directory.

# Public URL used by browser and token issuer
KEYCLOAK_PUBLIC_URL=http://localhost:8080

# Realm imported from keycloak/realm-export.json
REALM=iom-itb-sso

# Keycloak bootstrap admin
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# Postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=postgres

# Optional: set explicitly in production
KC_PROXY=edge
KC_HOSTNAME_STRICT=true
KC_HOSTNAME_STRICT_HTTPS=true
